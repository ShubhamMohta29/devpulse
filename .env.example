# ─────────────────────────────────────────────────────────────
# DevPulse — Environment Variables
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────

# ── Gemini / Google AI ─────────────────────────────────────
# Required for the agent to function.
# Get from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# Gemini model to use (default shown; override if needed)
GEMINI_MODEL=gemini-1.5-flash

# ── Google Cloud / BigQuery ────────────────────────────────
# Your GCP project ID (visible at top of Google Cloud Console)
GCP_PROJECT_ID=your-gcp-project-id

# BigQuery dataset name (default: devpulse)
BQ_DATASET=devpulse

# Path to GCP service account JSON key file
# Create: GCP Console → IAM → Service Accounts → create with
#   roles/bigquery.dataEditor + roles/bigquery.jobUser
# Then: Actions → Manage keys → Add key → JSON
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ── Fivetran ───────────────────────────────────────────────
# API key + secret from: Fivetran Dashboard → Settings → API Config
FIVETRAN_API_KEY=your-fivetran-api-key
FIVETRAN_API_SECRET=your-fivetran-api-secret

# Connector IDs: Fivetran Dashboard → Connectors → [connector] → Settings
GITHUB_CONNECTOR_ID=your-github-connector-id
JIRA_CONNECTOR_ID=your-jira-connector-id

# ── Slack (optional) ───────────────────────────────────────
# Incoming Webhook URL from Slack App settings
# Leave empty to disable Slack notifications
SLACK_WEBHOOK_URL=

# ── Runtime ────────────────────────────────────────────────
# Set to "true" to run against mock fixture data instead of
# real BigQuery + Fivetran. You still need GOOGLE_API_KEY.
MOCK_MODE=false

# Interface mode: "cli" or "api"
MODE=api

# FastAPI server settings (used when MODE=api)
API_HOST=0.0.0.0
API_PORT=8000
